{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "npm run pull-stats",
    "dev": "next dev",
    "dev:quick": "next dev",
    "dev:fresh": "npm run pull-stats && node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\" && next dev",
    "build": "next build",
    "postbuild": "node scripts/write-build-fingerprint.cjs",
    "prestart": "node scripts/assert-build-fingerprint.cjs",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "npm run build && node scripts/smoke.cjs",
    "pull-stats": "node scripts/pull-stats.mjs",
    "docker:watch": "docker compose -f ../docker-compose.yml watch web"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "mysql2": "^3.14.0",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "vitest": "^3.1.1"
  }
}
