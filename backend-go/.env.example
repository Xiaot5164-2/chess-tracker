# Copy to backend-go/.env (gitignored). Used by Go worker and Docker Compose (--env-file).
#
# MySQL（密码含特殊字符请在 mysql:// URL 中做百分号编码）
DATABASE_URL=mysql://chess:chess@127.0.0.1:3306/chess_tracker
#
# DATABASE_URL_FALLBACK=mysql://user:password@other-host:3306/chess_tracker
# DATABASE_PREFER_IPV4=1
# DATABASE_IPV6_ONLY=1
#
# Local one-shot sync from web: npm run pull-stats（需 web/.env.local 的 DATABASE_URL）

# Optional:
# RUN_ONCE=1
# 棋钟分由 games→daily_game_stats；已弃用 hourly daily_stats（见 mysql/migrations/005）
# POLL_INTERVAL=1h
# WORKER_CONCURRENCY=2
# PUZZLE_SYNC_INTERVAL=10m
#
# 对局（Chess.com → games，每轮后重算 daily_game_stats）：
# SYNC_GAMES=1
# GAMES_SYNC_INTERVAL=10m
# GAMES_INCREMENTAL_DAYS=2
# GAMES_BACKFILL_ON_START=1
# GAMES_BACKFILL_DAYS=90
# PUZZLE_HTTP_TIMEOUT=12s
# SYNC_GAMES=1 时，每轮 games 同步后全量重算 daily_game_stats（盘数、胜/负/和）
# DAILY_GAME_STATS_LOOKBACK_DAYS=120
