# Copy values into LOCAL files only — do not commit real secrets.
#
# Next.js: create web/.env.local (gitignored) with:
# MySQL connection (same schema as Worker / mysql/migrations):
DATABASE_URL=mysql://user:password@127.0.0.1:3306/chess_tracker
#
# 添加学生时拉取 Chess.com 对局归档的天数（默认 90，仅服务端）：
# ADD_PLAYER_GAMES_BACKFILL_DAYS=90
#
# Optional: 排行榜「删除学生」确认密码；不设则默认为 19930426（生产环境请设置强密码并勿提交真实值）
# STUDENT_DELETE_PASSWORD=
#
# Go worker — MySQL URI (put in backend-go/.env, or repo-root .env for scripts).
# Do NOT expose this URL to the browser in client bundles.
# DATABASE_URL_FALLBACK=mysql://user:password@fallback-host:3306/chess_tracker
#
# Docker worker (repo root): copy DATABASE_URL into backend-go/.env, then:
#   docker compose up -d --build worker
# Local DB + worker:
#   DATABASE_URL=mysql://chess:chess@mysql:3306/chess_tracker
#   docker compose --profile local-db up -d --build
#
# DATABASE_PREFER_IPV4=1
# DATABASE_IPV6_ONLY=1
#
# WORKER_TUNING=optional
# POLL_INTERVAL=1h
# WORKER_CONCURRENCY=2
# RUN_ONCE=1
# PUZZLE_ONLY=1   # 仅谜题 callback（daily_puzzle_stats / puzzle_snapshots）；不写 games、不重算棋钟日表、不 pub /stats。可与 RUN_ONCE=1 用于每日单次：./scripts/daily-puzzle-sync.sh
#
# 对局归档（Chess.com games Pub API → MySQL games 表）：
# SYNC_GAMES=1
# GAMES_BACKFILL_ON_START=1
# GAMES_BACKFILL_DAYS=90
# GAMES_SYNC_INTERVAL=10m
# GAMES_INCREMENTAL_DAYS=2
